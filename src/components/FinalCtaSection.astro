---
import Reveal from "./motion/Reveal";
---

<section class="section-shell section-spacing" id="cta-final">
  <Reveal client:load direction="up">
    <div class="final-cta final-cta--centered">
      <div class="section-copy section-copy--centered-text max-w-3xl">
        <div class="section-kicker">09 · Acceso temprano</div>
        <h2 class="section-title">La salud mental necesita nuevas métricas.</h2>
        <div class="section-body section-body--centered">
          <p>
            Prysmia Care está construyendo una nueva infraestructura para entender la evolución de la
            depresión.
          </p>
          <p>
            Invitamos a psicólogos y clínicas innovadoras a participar en las primeras cohortes de
            uso clínico.
          </p>
        </div>
      </div>

      <div class="final-cta__actions final-cta__actions--centered">
        <a
          href="https://forms.gle/1mjV3x8cjYAstQPw8"
          target="_blank"
          rel="noreferrer noopener"
          class="button-primary justify-center">
          Solicitar acceso temprano
        </a>
        <p class="final-cta__microcopy">
          Cupos limitados para clínicas y profesionales en España y Latinoamérica.
        </p>
      </div>
    </div>
  </Reveal>
</section>
