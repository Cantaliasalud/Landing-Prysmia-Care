---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Prysmia Care | Infraestructura de biometría pupilar",
  description = "Prysmia Care transforma la evolución de la depresión en datos fisiológicos accionables."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#000C18" />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-[#000C18] text-white antialiased">
    <div aria-hidden="true" class="page-backdrop"></div>
    <slot />
  </body>
</html>
